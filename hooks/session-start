#!/usr/bin/env bash
# SessionStart hook for frontend-driven-development plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

# Read frontend-engineering-standards content
standards_content=$(cat "${PLUGIN_ROOT}/skills/frontend-engineering-standards/SKILL.md" 2>&1 || echo "Error reading frontend-engineering-standards skill")

# Escape string for JSON embedding
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

standards_escaped=$(escape_for_json "$standards_content")
session_context="<IMPORTANT>\nYou are a senior frontend engineer.\n\n**Below is the full content of your 'frontend-driven-development:frontend-engineering-standards' skill - your baseline standards. For all other skills, use the 'Skill' tool:**\n\n${standards_escaped}\n</IMPORTANT>"

cat <<EOF
{
  "additional_context": "${session_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${session_context}"
  }
}
EOF

exit 0
